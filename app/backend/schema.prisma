// Uses SQLite for local development

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Jury {
  id       Int       @id @default(autoincrement())
  name     String
  teachers Teacher[] @relation("JuryTeachers")
  students Student[] @relation("JuryStudents")
  
  sessionJuries SessionJury[] @relation("JurySessionJury")
  sessionStudents SessionStudent[] @relation("JurySessionStudent")

  @@map("jury")
}

model Teacher {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String
  jury     String?
  juryId   Int?
  juryRef  Jury?   @relation("JuryTeachers", fields: [juryId], references: [id])
  admin    Boolean @default(false)

  questionnaireJuries QuestionnaireJuryMember[]
  sessionJuries SessionJury[]
}

model Student {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  password     String
  nom          String?
  prenom       String?
  assignedJury String?
  juryId       Int?
  juryRef      Jury?   @relation("JuryStudents", fields: [juryId], references: [id])
  submissions  Submission[]
  isTest       Boolean @default(false)

  questionnaireStudents QuestionnaireStudentMember[]
  sessionStudents SessionStudent[]
}

model Questionnaire {
  id               Int                @id @default(autoincrement())
  title            String
  date             DateTime           @default(now())
  openForStudents  Boolean            @default(false)
  gradingMode      String             @default("points")
  maxScore         Float              @default(20)
  audience         String             @default("teachers")
  showResults      Boolean            @default(false)
  shuffleQuestions Boolean            @default(false)
  categories       QuestionCategory[]
  submissions      Submission[]

  juryMembers QuestionnaireJuryMember[]
  students    QuestionnaireStudentMember[]
  juryGroups  String?
  sessions    Session[]
}

model QuestionnaireJuryMember {
  questionnaireId Int
  teacherId       Int

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  teacher       Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([questionnaireId, teacherId])
}

model QuestionnaireStudentMember {
  questionnaireId Int
  studentId       Int

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([questionnaireId, studentId])
}

model Session {
  id              Int       @id @default(autoincrement())
  name            String
  date            DateTime?
  active          Boolean   @default(false)
  questionnaireId Int
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  
  juries          SessionJury[]
  students        SessionStudent[]
  
  @@index([questionnaireId])
}

model SessionJury {
  id              Int    @id @default(autoincrement())
  sessionId       Int
  session         Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  juryId          Int
  jury            Jury   @relation("JurySessionJury", fields: [juryId], references: [id], onDelete: Cascade)
  
  teacherId       Int
  teacher         Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  @@unique([sessionId, teacherId])
  @@index([sessionId])
  @@index([juryId])
  @@index([teacherId])
}

model SessionStudent {
  id              Int    @id @default(autoincrement())
  sessionId       Int
  session         Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  studentId       Int
  student         Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  juryId          Int
  jury            Jury   @relation("JurySessionStudent", fields: [juryId], references: [id], onDelete: Cascade)
  
  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([juryId])
}

model QuestionCategory {
  id              Int           @id @default(autoincrement())
  title           String?
  questions       Question[]
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id])
  questionnaireId Int
  currentNote     Float
}

model Question {
  id                 Int              @id @default(autoincrement())
  title              String
  questionCategoryId Int
  questionnaire      QuestionCategory @relation(fields: [questionCategoryId], references: [id])

  elements QuestionElement[]
}

model QuestionElement {
  id    Int    @id @default(autoincrement())
  type  String // radio, checkbox, text, etc.
  title String

  questionId Int
  question   Question @relation(fields: [questionId], references: [id])

  priority        Int
  evaluatingType  Int // reduce, increase, multiply, set max points
  evaluatingValue Float
}

model Submission {
  id              Int       @id @default(autoincrement())
  questionnaireId Int
  questionnaire   Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)
  
  studentId Int?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  
  answers   String? // JSON array of { questionId, answer }
  submittedAt DateTime @default(now())
  
  @@index([questionnaireId])
  @@index([studentId])
}
